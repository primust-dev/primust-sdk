<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <RootNamespace>Primust</RootNamespace>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Version>0.1.0</Version>
    <Description>
      Prove governance ran. Disclose nothing.
      Pipeline/Run/Record API for issuing Verifiable Process Execution Credentials (VPECs).
      Raw input committed locally — never transmitted.
    </Description>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.8.0" Condition="'$(IsTestProject)' == 'true'" />
    <PackageReference Include="xunit" Version="2.6.2" Condition="'$(IsTestProject)' == 'true'" />
  </ItemGroup>

</Project>
