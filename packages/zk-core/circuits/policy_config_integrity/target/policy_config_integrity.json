{"noir_version":"1.0.0-beta.18+99bb8b5cf33d7669adbdef096b12d80f30b4c0c9","hash":"14698799094809100894","abi":{"parameters":[{"name":"policy_hash","type":{"kind":"field"},"visibility":"public"},{"name":"trace_count","type":{"kind":"integer","sign":"unsigned","width":32},"visibility":"public"},{"name":"trace_policy_hashes","type":{"kind":"array","length":256,"type":{"kind":"field"}},"visibility":"private"},{"name":"actual_count","type":{"kind":"integer","sign":"unsigned","width":32},"visibility":"private"}],"return_type":null,"error_types":{}},"bytecode":"","debug_symbols":"","file_map":{"51":{"source":"// Policy Config Integrity Circuit\n//\n// Proves the same policy snapshot hash was used across all traces\n// in a process run. Prevents mid-run policy substitution where\n// different traces could be evaluated against different policies.\n//\n// Public inputs:\n//   - policy_hash: expected policy snapshot hash\n//   - trace_count: number of traces in the run\n//\n// Private inputs:\n//   - trace_policy_hashes: policy hash recorded per trace\n//   - actual_count: actual number of traces\n//\n// Constraints:\n//   1. All trace_policy_hashes[i] == policy_hash for i < actual_count\n//   2. actual_count == trace_count\n//   3. actual_count > 0 (non-vacuous proof)\n\nfn main(\n    // Public inputs\n    policy_hash: pub Field,\n    trace_count: pub u32,\n\n    // Private inputs\n    trace_policy_hashes: [Field; 256],\n    actual_count: u32,\n) {\n    // Constraint 2: counts must match\n    assert(actual_count == trace_count);\n\n    // Constraint 3: non-vacuous -- at least one trace\n    assert(actual_count > 0);\n\n    // Constraint 1: every trace used the same policy\n    for i in 0..256 {\n        if (i as u32) < actual_count {\n            assert(trace_policy_hashes[i] == policy_hash);\n        }\n    }\n}\n","path":"/Users/adamlayman/primust/packages/zk-core/circuits/policy_config_integrity/src/main.nr"}},"expression_width":{"Bounded":{"width":4}}}