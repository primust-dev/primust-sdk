# Primust API — Environment Variables
# Copy to .env and fill in values.

# ── Required ──
DATABASE_URL_US=postgresql://user:pass@host/primust_us
DATABASE_URL_EU=postgresql://user:pass@host/primust_eu

# ── Auth (required unless PRIMUST_DEV_MODE=true) ──
PRIMUST_API_KEY_SECRET=your-hmac-secret-here
CLERK_JWKS_URL=https://your-clerk-instance.clerk.accounts.dev/.well-known/jwks.json
# CLERK_SECRET_KEY=sk_live_xxx  # Fallback — prefer JWKS

# ── KMS (required unless PRIMUST_DEV_MODE=true) ──
PRIMUST_KMS_KEY_US=projects/my-project/locations/us-east1/keyRings/primust/cryptoKeys/sign-us
PRIMUST_KMS_KEY_EU=projects/my-project/locations/europe-west1/keyRings/primust/cryptoKeys/sign-eu

# ── TSA (required unless PRIMUST_DEV_MODE=true) ──
PRIMUST_TSA_URL_US=https://timestamp.digicert.com
PRIMUST_TSA_URL_EU=https://timestamp.digicert.com

# ── R2 Storage ──
R2_BUCKET_US=primust-us
R2_BUCKET_EU=primust-eu

# ── CORS ──
CORS_ALLOWED_ORIGINS=https://app.primust.com,https://dashboard.primust.com

# ── Rate Limiting ──
PRIMUST_RATE_LIMIT_RPM=120

# ── Development Mode ──
# Set to "true" to relax auth/KMS/TSA requirements for local development.
# NEVER enable in production.
# PRIMUST_DEV_MODE=true
