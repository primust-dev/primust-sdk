<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>Primust</RootNamespace>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <Version>0.1.0</Version>
    <PackageId>Primust.SDK</PackageId>
    <Authors>Primust</Authors>
    <PackageProjectUrl>https://primust.com</PackageProjectUrl>
    <RepositoryUrl>https://github.com/primust/primust</RepositoryUrl>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <Description>
      Prove governance ran. Disclose nothing.
      Pipeline/Run/Record API for issuing Verifiable Process Execution Credentials (VPECs).
      Raw input committed locally — never transmitted.
    </Description>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Primust.Tests" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="tests/**" />
  </ItemGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="" Condition="Exists('README.md')" />
  </ItemGroup>

</Project>
