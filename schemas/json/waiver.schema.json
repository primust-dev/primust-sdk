{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://primust.com/schemas/waiver/v3.0.0",
  "title": "Primust Waiver",
  "description": "Waiver record — provisional-frozen at schema_version 3.0.0. expires_at REQUIRED, max 90 days.",
  "type": "object",
  "required": [
    "waiver_id",
    "gap_id",
    "org_id",
    "requestor_user_id",
    "approver_user_id",
    "reason",
    "compensating_control",
    "expires_at",
    "signature",
    "approved_at"
  ],
  "properties": {
    "waiver_id": { "type": "string" },
    "gap_id": { "type": "string" },
    "org_id": { "type": "string" },
    "requestor_user_id": { "type": "string" },
    "approver_user_id": { "type": "string" },
    "reason": { "type": "string", "minLength": 50 },
    "compensating_control": { "type": ["string", "null"] },
    "expires_at": { "type": "string", "format": "date-time" },
    "signature": { "$ref": "#/$defs/SignatureEnvelopeRef" },
    "approved_at": { "type": "string", "format": "date-time" }
  },
  "not": { "required": ["reliance_mode"] },
  "additionalProperties": false,
  "$defs": {
    "SignatureEnvelopeRef": {
      "type": "object",
      "required": ["signer_id", "kid", "algorithm", "signature", "signed_at"],
      "properties": {
        "signer_id": { "type": "string" },
        "kid": { "type": "string" },
        "algorithm": { "type": "string", "const": "Ed25519" },
        "signature": { "type": "string" },
        "signed_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    }
  }
}
