{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://primust.com/schemas/policy_pack/v4.0.0",
  "title": "Primust PolicyPack",
  "description": "Policy pack definition — provisional-frozen at schema_version 3.0.0",
  "type": "object",
  "required": [
    "policy_pack_id",
    "org_id",
    "name",
    "version",
    "checks",
    "created_at",
    "signer_id",
    "kid",
    "signature"
  ],
  "properties": {
    "policy_pack_id": { "type": "string" },
    "org_id": { "type": "string" },
    "name": { "type": "string" },
    "version": { "type": "string" },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["check_id", "manifest_id", "required", "evaluation_scope", "action_unit_count"],
        "properties": {
          "check_id": { "type": "string" },
          "manifest_id": { "type": "string" },
          "required": { "type": "boolean" },
          "evaluation_scope": {
            "type": "string",
            "enum": ["per_run", "per_action_unit", "per_surface", "per_window"]
          },
          "action_unit_count": { "type": ["integer", "null"] }
        },
        "additionalProperties": false
      }
    },
    "created_at": { "type": "string", "format": "date-time" },
    "signer_id": { "type": "string" },
    "kid": { "type": "string" },
    "signature": { "$ref": "#/$defs/SignatureEnvelopeRef" },
    "compliance_requirements": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["require_actor_id", "require_explanation_commitment", "require_bias_audit", "require_retention_policy", "require_risk_classification"],
          "properties": {
            "require_actor_id": { "type": "boolean" },
            "require_explanation_commitment": {
              "oneOf": [
                { "type": "null" },
                {
                  "type": "object",
                  "required": ["on_check_result", "on_check_types"],
                  "properties": {
                    "on_check_result": { "type": "array", "items": { "type": "string", "enum": ["fail", "override"] } },
                    "on_check_types": { "type": "array", "items": { "type": "string" } }
                  },
                  "additionalProperties": false
                }
              ]
            },
            "require_bias_audit": {
              "oneOf": [
                { "type": "null" },
                {
                  "type": "object",
                  "required": ["on_check_types", "protected_categories"],
                  "properties": {
                    "on_check_types": { "type": "array", "items": { "type": "string" } },
                    "protected_categories": { "type": "array", "items": { "type": "string" } }
                  },
                  "additionalProperties": false
                }
              ]
            },
            "require_retention_policy": { "type": "boolean" },
            "require_risk_classification": { "type": "boolean" }
          },
          "additionalProperties": false
        }
      ]
    },
    "sla_policy": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["proof_level_floor_minimum", "provable_surface_minimum", "max_open_critical_gaps", "max_open_high_gaps", "retention_policy_required"],
          "properties": {
            "proof_level_floor_minimum": { "type": "string", "enum": ["mathematical", "verifiable_inference", "execution", "witnessed", "attestation"] },
            "provable_surface_minimum": { "type": "number", "minimum": 0, "maximum": 1 },
            "max_open_critical_gaps": { "type": "integer", "minimum": 0 },
            "max_open_high_gaps": { "type": ["integer", "null"], "minimum": 0 },
            "retention_policy_required": { "type": ["string", "null"] }
          },
          "additionalProperties": false
        }
      ]
    }
  },
  "not": { "required": ["reliance_mode"] },
  "additionalProperties": false,
  "$defs": {
    "SignatureEnvelopeRef": {
      "type": "object",
      "required": ["signer_id", "kid", "algorithm", "signature", "signed_at"],
      "properties": {
        "signer_id": { "type": "string" },
        "kid": { "type": "string" },
        "algorithm": { "type": "string", "const": "Ed25519" },
        "signature": { "type": "string" },
        "signed_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    }
  }
}
