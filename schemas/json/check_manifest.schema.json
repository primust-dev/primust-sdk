{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://primust.com/schemas/check_manifest/v4.0.0",
  "title": "Primust CheckManifest",
  "description": "Check manifest definition — provisional-frozen at schema_version 3.0.0",
  "type": "object",
  "required": [
    "manifest_id",
    "manifest_hash",
    "domain",
    "name",
    "semantic_version",
    "check_type",
    "implementation_type",
    "supported_proof_level",
    "evaluation_scope",
    "evaluation_window_seconds",
    "stages",
    "aggregation_config",
    "freshness_threshold_hours",
    "benchmark",
    "model_or_tool_hash",
    "publisher",
    "signer_id",
    "kid",
    "signed_at",
    "signature"
  ],
  "properties": {
    "manifest_id": { "type": "string" },
    "manifest_hash": { "type": "string" },
    "domain": {
      "type": "string",
      "enum": ["ai_agent", "cicd", "financial", "pharma", "generic"]
    },
    "name": { "type": "string" },
    "semantic_version": { "type": "string" },
    "check_type": { "type": "string" },
    "implementation_type": {
      "type": "string",
      "enum": ["ml_model", "rule", "threshold", "approval_chain", "zkml_model", "custom"]
    },
    "supported_proof_level": {
      "type": "string",
      "enum": ["mathematical", "verifiable_inference", "execution", "witnessed", "attestation"]
    },
    "evaluation_scope": {
      "type": "string",
      "enum": ["per_run", "per_action_unit", "per_surface", "per_window"]
    },
    "evaluation_window_seconds": { "type": ["integer", "null"] },
    "stages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["stage", "name", "type", "proof_level", "redacted"],
        "properties": {
          "stage": { "type": "integer" },
          "name": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["deterministic_rule", "ml_model", "zkml_model", "statistical_test", "custom_code", "witnessed", "policy_engine", "llm_api", "open_source_ml", "hardware_attested"]
          },
          "proof_level": {
            "type": "string",
            "enum": ["mathematical", "verifiable_inference", "execution", "witnessed", "attestation"]
          },
          "redacted": { "type": "boolean" },
          "model_id": { "type": "string", "description": "For open_source_ml: public model card identifier" },
          "model_version_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$", "description": "For open_source_ml: sha256 of weights files" },
          "tee_type": { "type": "string", "enum": ["sgx", "sev", "trustzone", "tpm"], "description": "For hardware_attested: TEE type" },
          "enclave_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$", "description": "For hardware_attested: sha256 of enclave code (MRENCLAVE)" },
          "engine": { "type": "string", "enum": ["opa", "cedar"], "description": "For policy_engine: engine type" },
          "policy_bundle_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$", "description": "For policy_engine: sha256 of policy bundle" },
          "committed_random_seed": { "type": "boolean", "description": "For statistical_test: true if random seed is committed for reproducibility" }
        },
        "additionalProperties": false
      }
    },
    "aggregation_config": {
      "type": "object",
      "required": ["method", "threshold"],
      "properties": {
        "method": {
          "type": "string",
          "enum": ["all_stages_must_pass", "worst_case", "threshold_vote", "sequential_gate"]
        },
        "threshold": { "type": ["number", "null"] }
      },
      "additionalProperties": false
    },
    "freshness_threshold_hours": { "type": ["number", "null"] },
    "benchmark": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "required": ["benchmark_id", "benchmark_hash", "precision", "recall", "f1", "test_dataset", "published_by"],
          "properties": {
            "benchmark_id": { "type": ["string", "null"] },
            "benchmark_hash": { "type": ["string", "null"] },
            "precision": { "type": ["number", "null"] },
            "recall": { "type": ["number", "null"] },
            "f1": { "type": ["number", "null"] },
            "test_dataset": { "type": ["string", "null"] },
            "published_by": { "type": ["string", "null"] }
          },
          "additionalProperties": false
        }
      ]
    },
    "model_or_tool_hash": { "type": ["string", "null"] },
    "prompt_version_id": { "type": ["string", "null"] },
    "prompt_approved_by": { "type": ["string", "null"], "pattern": "^user_[0-9a-f\\-]{36}$" },
    "prompt_approved_at": { "type": ["string", "null"], "format": "date-time" },
    "publisher": { "type": "string" },
    "signer_id": { "type": "string" },
    "kid": { "type": "string" },
    "signed_at": { "type": "string", "format": "date-time" },
    "signature": { "$ref": "#/$defs/SignatureEnvelopeRef" }
  },
  "not": { "required": ["reliance_mode"] },
  "additionalProperties": false,
  "$defs": {
    "SignatureEnvelopeRef": {
      "type": "object",
      "required": ["signer_id", "kid", "algorithm", "signature", "signed_at"],
      "properties": {
        "signer_id": { "type": "string" },
        "kid": { "type": "string" },
        "algorithm": { "type": "string", "const": "Ed25519" },
        "signature": { "type": "string" },
        "signed_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    }
  }
}
