{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://primust.com/schemas/artifact/v3.0.0",
  "title": "Primust VPEC Artifact",
  "description": "Verified Process Execution Credential — provisional-frozen at schema_version 3.0.0",
  "type": "object",
  "required": [
    "vpec_id",
    "schema_version",
    "org_id",
    "run_id",
    "workflow_id",
    "process_context_hash",
    "policy_snapshot_hash",
    "policy_basis",
    "partial",
    "surface_summary",
    "proof_level",
    "proof_distribution",
    "state",
    "coverage",
    "gaps",
    "manifest_hashes",
    "commitment_root",
    "commitment_algorithm",
    "zk_proof",
    "issuer",
    "signature",
    "timestamp_anchor",
    "transparency_log",
    "issued_at",
    "pending_flags",
    "test_mode"
  ],
  "not": {
    "required": ["reliance_mode"]
  },
  "properties": {
    "vpec_id": {
      "type": "string",
      "pattern": "^vpec_[0-9a-f\\-]{36}$",
      "description": "Unique credential identifier: vpec_{uuid}"
    },
    "schema_version": {
      "type": "string",
      "const": "3.0.0"
    },
    "org_id": {
      "type": "string",
      "minLength": 1,
      "description": "Issuing organization identifier"
    },
    "run_id": {
      "type": "string",
      "pattern": "^run_[0-9a-f\\-]{36}$",
      "description": "Process run identifier: run_{uuid}"
    },
    "workflow_id": {
      "type": "string",
      "minLength": 1
    },
    "process_context_hash": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^poseidon2:[0-9a-f]+$"
        },
        { "type": "null" }
      ],
      "description": "Customer-computed config epoch hash. Primust never sees raw config. null when not provided at Pipeline() init."
    },
    "policy_snapshot_hash": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "policy_basis": {
      "type": "string",
      "enum": [
        "P1_self_declared",
        "P2_baseline_aligned",
        "P3_baseline_plus_deviations"
      ]
    },
    "partial": {
      "type": "boolean",
      "description": "true when issued via p.close(partial=True). Coverage credit NOT awarded for partial VPECs."
    },
    "surface_summary": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/SurfaceEntry" }
    },
    "proof_level": {
      "$ref": "#/$defs/ProofLevel",
      "description": "MUST equal proof_distribution.weakest_link. Computed — never set manually."
    },
    "proof_distribution": { "$ref": "#/$defs/ProofDistribution" },
    "state": {
      "type": "string",
      "enum": ["provisional", "signed", "final"]
    },
    "coverage": { "$ref": "#/$defs/Coverage" },
    "gaps": {
      "type": "array",
      "items": { "$ref": "#/$defs/GapEntry" },
      "description": "Inline objects — verifier must not need a second API call to read gap type/severity."
    },
    "manifest_hashes": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "pattern": "^sha256:[0-9a-f]{64}$"
      },
      "description": "Map of manifest_id → sha256:hex. MUST be an object, not an array."
    },
    "commitment_root": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^poseidon2:[0-9a-f]+$"
        },
        { "type": "null" }
      ],
      "description": "Merkle root over all CheckExecutionRecord commitment_hashes. null when run has zero records."
    },
    "commitment_algorithm": {
      "type": "string",
      "enum": ["poseidon2", "sha256"]
    },
    "zk_proof": {
      "oneOf": [
        { "$ref": "#/$defs/ZkProof" },
        { "type": "null" }
      ]
    },
    "issuer": { "$ref": "#/$defs/Issuer" },
    "signature": { "$ref": "#/$defs/SignatureEnvelope" },
    "timestamp_anchor": { "$ref": "#/$defs/TimestampAnchor" },
    "transparency_log": { "$ref": "#/$defs/TransparencyLog" },
    "issued_at": {
      "type": "string",
      "format": "date-time"
    },
    "pending_flags": { "$ref": "#/$defs/PendingFlags" },
    "test_mode": {
      "type": "boolean",
      "description": "true when issued with pk_test_xxx key. primust-verify rejects test_mode: true in --production mode."
    }
  },
  "additionalProperties": false,
  "$defs": {
    "ProofLevel": {
      "type": "string",
      "enum": [
        "mathematical",
        "execution_zkml",
        "execution",
        "witnessed",
        "attestation"
      ]
    },
    "SurfaceEntry": {
      "type": "object",
      "required": [
        "surface_id",
        "surface_type",
        "observation_mode",
        "proof_ceiling",
        "scope_type",
        "scope_description",
        "surface_coverage_statement"
      ],
      "properties": {
        "surface_id": { "type": "string", "minLength": 1 },
        "surface_type": {
          "type": "string",
          "enum": [
            "in_process_adapter",
            "middleware_interceptor",
            "platform_event_feed",
            "audit_log_ingest",
            "manual_assertion"
          ]
        },
        "observation_mode": {
          "type": "string",
          "enum": [
            "pre_action",
            "in_flight",
            "post_action_realtime",
            "post_action_batch"
          ]
        },
        "proof_ceiling": { "$ref": "#/$defs/ProofLevel" },
        "scope_type": {
          "type": "string",
          "enum": [
            "full_workflow",
            "orchestration_boundary",
            "platform_logged_events",
            "component_scope",
            "partial_unknown"
          ]
        },
        "scope_description": { "type": "string" },
        "surface_coverage_statement": { "type": "string" }
      },
      "additionalProperties": false
    },
    "ProofDistribution": {
      "type": "object",
      "required": [
        "mathematical",
        "execution_zkml",
        "execution",
        "witnessed",
        "attestation",
        "weakest_link",
        "weakest_link_explanation"
      ],
      "properties": {
        "mathematical": { "type": "integer", "minimum": 0 },
        "execution_zkml": { "type": "integer", "minimum": 0 },
        "execution": { "type": "integer", "minimum": 0 },
        "witnessed": { "type": "integer", "minimum": 0 },
        "attestation": { "type": "integer", "minimum": 0 },
        "weakest_link": { "$ref": "#/$defs/ProofLevel" },
        "weakest_link_explanation": { "type": "string" }
      },
      "additionalProperties": false
    },
    "Coverage": {
      "type": "object",
      "required": [
        "records_total",
        "records_pass",
        "records_fail",
        "records_degraded",
        "records_not_applicable",
        "policy_coverage_pct",
        "instrumentation_surface_pct",
        "instrumentation_surface_basis"
      ],
      "properties": {
        "records_total": { "type": "integer", "minimum": 0 },
        "records_pass": { "type": "integer", "minimum": 0 },
        "records_fail": { "type": "integer", "minimum": 0 },
        "records_degraded": { "type": "integer", "minimum": 0 },
        "records_not_applicable": { "type": "integer", "minimum": 0 },
        "policy_coverage_pct": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "DENOMINATOR 1: % of required checks (per PolicySnapshot) that ran."
        },
        "instrumentation_surface_pct": {
          "oneOf": [
            { "type": "number", "minimum": 0, "maximum": 100 },
            { "type": "null" }
          ],
          "description": "DENOMINATOR 2: % of total workflow universe in instrumentation scope. null when scope_type is partial_unknown. NEVER collapse with policy_coverage_pct."
        },
        "instrumentation_surface_basis": {
          "type": "string",
          "description": "Plain-English statement of what the surface denominator represents."
        }
      },
      "additionalProperties": false
    },
    "GapEntry": {
      "type": "object",
      "required": ["gap_id", "gap_type", "severity"],
      "properties": {
        "gap_id": { "type": "string", "minLength": 1 },
        "gap_type": {
          "type": "string",
          "enum": [
            "check_not_executed",
            "enforcement_override",
            "engine_error",
            "check_degraded",
            "external_boundary_traversal",
            "lineage_token_missing",
            "admission_gate_override",
            "check_timing_suspect",
            "reviewer_credential_invalid",
            "witnessed_display_missing",
            "witnessed_rationale_missing",
            "deterministic_consistency_violation",
            "skip_rationale_missing",
            "policy_config_drift",
            "zkml_proof_pending_timeout",
            "zkml_proof_failed"
          ]
        },
        "severity": {
          "type": "string",
          "enum": [
            "Critical",
            "High",
            "Medium",
            "Low",
            "Informational"
          ]
        }
      },
      "additionalProperties": false
    },
    "ZkProof": {
      "type": "object",
      "required": [
        "circuit",
        "proof_bytes",
        "public_inputs",
        "verified_at",
        "prover",
        "prover_system",
        "nargo_version"
      ],
      "properties": {
        "circuit": { "type": "string" },
        "proof_bytes": { "type": "string" },
        "public_inputs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "verified_at": { "type": "string", "format": "date-time" },
        "prover": {
          "type": "string",
          "enum": ["local", "modal_cpu", "modal_gpu"]
        },
        "prover_system": {
          "type": "string",
          "enum": ["ultrahonk", "ezkl", "groth16_bionetta"]
        },
        "nargo_version": {
          "oneOf": [
            { "type": "string" },
            { "type": "null" }
          ]
        }
      },
      "additionalProperties": false
    },
    "Issuer": {
      "type": "object",
      "required": [
        "signer_id",
        "kid",
        "algorithm",
        "public_key_url",
        "org_region"
      ],
      "properties": {
        "signer_id": { "type": "string", "minLength": 1 },
        "kid": { "type": "string", "minLength": 1 },
        "algorithm": {
          "type": "string",
          "const": "Ed25519"
        },
        "public_key_url": {
          "type": "string",
          "pattern": "^https://primust\\.com/\\.well-known/primust-pubkeys/.+\\.pem$"
        },
        "org_region": {
          "type": "string",
          "enum": ["us", "eu"]
        }
      },
      "additionalProperties": false
    },
    "SignatureEnvelope": {
      "type": "object",
      "required": [
        "signer_id",
        "kid",
        "algorithm",
        "signature",
        "signed_at"
      ],
      "properties": {
        "signer_id": { "type": "string", "minLength": 1 },
        "kid": { "type": "string", "minLength": 1 },
        "algorithm": {
          "type": "string",
          "const": "Ed25519"
        },
        "signature": {
          "type": "string",
          "description": "base64url-encoded Ed25519 signature"
        },
        "signed_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },
    "TimestampAnchor": {
      "type": "object",
      "required": ["type", "tsa", "value"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["rfc3161", "none"]
        },
        "tsa": {
          "type": "string",
          "enum": ["digicert_us", "digicert_eu", "none"]
        },
        "value": {
          "oneOf": [
            { "type": "string" },
            { "type": "null" }
          ],
          "description": "base64-encoded RFC 3161 token, or null"
        }
      },
      "additionalProperties": false
    },
    "TransparencyLog": {
      "type": "object",
      "required": ["rekor_log_id", "rekor_entry_url", "published_at"],
      "properties": {
        "rekor_log_id": {
          "oneOf": [
            { "type": "string" },
            { "type": "null" }
          ]
        },
        "rekor_entry_url": {
          "oneOf": [
            { "type": "string", "format": "uri" },
            { "type": "null" }
          ]
        },
        "published_at": {
          "oneOf": [
            { "type": "string", "format": "date-time" },
            { "type": "null" }
          ]
        }
      },
      "additionalProperties": false
    },
    "PendingFlags": {
      "type": "object",
      "required": [
        "signature_pending",
        "proof_pending",
        "zkml_proof_pending",
        "submission_pending",
        "rekor_pending"
      ],
      "properties": {
        "signature_pending": { "type": "boolean" },
        "proof_pending": { "type": "boolean", "description": "true when Noir/UltraHonk proof in-flight" },
        "zkml_proof_pending": { "type": "boolean", "description": "true when EZKL/Bionetta proof in-flight (Tier 2)" },
        "submission_pending": { "type": "boolean" },
        "rekor_pending": { "type": "boolean", "description": "true until transparency_log.rekor_log_id populated" }
      },
      "additionalProperties": false
    }
  }
}
